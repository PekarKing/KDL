<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/side_nav_bar"
    android:gravity="bottom"
    android:orientation="vertical"
    android:theme="@style/ThemeOverlay.AppCompat.Dark">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="99dp"
        android:layout_height="136dp"
        android:adjustViewBounds="true"
        android:cropToPadding="true"
        android:paddingLeft="@dimen/default_gap"
        android:paddingTop="@dimen/light_gray_bar_margin_sides"
        android:scaleType="center"
        app:srcCompat="@drawable/slide1" />

    <TextView
        android:id="@+id/navPoints"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:paddingLeft="@dimen/default_gap"
        android:paddingTop="2dp"
        android:text="0 баллов"
        android:textColor="@color/blue_gray"
        android:textSize="16dp"
        android:typeface="sans" />

    <TextView
        android:id="@+id/navEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="@dimen/default_gap"
        android:paddingTop="@dimen/keyboard_button_padding"
        android:text="Android Studio"
        android:textAllCaps="false"
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        android:textColor="@color/colorBlack"
        android:textSize="18dp"
        android:typeface="sans" />

    <TextView
        android:id="@+id/navUID"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingLeft="@dimen/default_gap"
        android:paddingBottom="@dimen/default_gap"
        android:text="android.studio@android.com"
        android:textColor="@color/blue_gray"
        android:textSize="16dp"
        android:typeface="sans" />

</LinearLayout>